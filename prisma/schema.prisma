generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum VerifiedStatus {
  none
  identity
  manual
}

enum PostVisibility {
  public
  verifiedOnly
  premiumOnly
  onlyMe
}

enum PostKind {
  regular
  checkin
  repost
  articleShare
}

enum FollowVisibility {
  all
  verified
  premium
  none
}

enum BirthdayVisibility {
  none
  monthDay
  full
}

enum PostMediaKind {
  image
  gif
  video
}

enum PostMediaSource {
  upload
  giphy
}

enum NotificationKind {
  comment
  boost
  repost
  follow
  followed_post
  followed_article
  mention
  nudge
  poll_results_ready
  generic
  coin_transfer
  message
  group_join_request
  community_group_member_joined
  community_group_join_approved
  community_group_join_rejected
  community_group_member_removed
  community_group_disbanded
  crew_invite_received
  crew_invite_accepted
  crew_invite_declined
  crew_invite_cancelled
  crew_member_joined
  crew_member_left
  crew_member_kicked
  crew_owner_transferred
  crew_owner_transfer_vote
  crew_wall_mention
  crew_disbanded
  community_group_invite_received
  community_group_invite_accepted
  community_group_invite_declined
  community_group_invite_cancelled
}

enum CoinTransferKind {
  transfer
  admin_adjust
  streak_reward
  verification_gift
}

enum FeedbackCategory {
  bug
  feature
  account
  other
}

enum FeedbackStatus {
  new
  triaged
  resolved
}

enum ReportTargetType {
  post
  user
}

enum ReportReason {
  spam
  harassment
  hate
  sexual
  violence
  illegal
  other
}

enum ReportStatus {
  pending
  dismissed
  actionTaken
}

enum VerificationRequestStatus {
  pending
  approved
  rejected
  cancelled
}

enum MessageConversationType {
  direct
  group
  crew_wall
}

enum MessageParticipantStatus {
  pending
  accepted
}

enum MessageParticipantRole {
  owner
  member
}

enum EmailActionTokenPurpose {
  verifyEmail
  unsubscribeDailyDigest
}

enum SubscriptionGrantTier {
  premium
  premiumPlus
}

enum SubscriptionGrantSource {
  admin
  referral
}

enum TaxonomyTermKind {
  topic
  subtopic
  tag
}

enum TaxonomyTermStatus {
  active
  hidden
}

enum TaxonomyAliasSource {
  topic_config
  article_tag
  hashtag
  manual
}

enum TaxonomyEdgeRelation {
  parent
  related
  synonym
}

enum CommunityGroupJoinPolicy {
  open
  approval
}

enum CommunityGroupMemberRole {
  owner
  moderator
  member
}

enum CommunityGroupMemberStatus {
  active
  pending
}

/**
 * Lifecycle of a CommunityGroupInvite. The same row is reused across the
 * `pending -> declined -> pending` re-invite path so we keep historical
 * timestamps (`lastDeclinedAt`, `lastNotifiedAt`) for the cooldowns.
 */
enum CommunityGroupInviteStatus {
  pending
  accepted
  declined
  cancelled
  expired
}

enum CrewMemberRole {
  owner
  member
}

enum CrewInviteStatus {
  pending
  accepted
  declined
  cancelled
  expired
}

enum SpaceMode {
  NONE
  WATCH_PARTY
  RADIO
}

model User {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  phone     String    @unique
  email     String?   @unique
  /** When the current email was verified by the user (null means unverified). */
  emailVerifiedAt DateTime?
  /** When we last requested verification for the current email (used for resend throttling). */
  emailVerificationRequestedAt DateTime?
  // Username stored as entered (case preserved). Uniqueness is enforced case-insensitively
  // via a functional unique index on LOWER(username) in a migration.
  username String?
  // Public profile fields.
  name String?
  bio  String?
  website String?
  /** Raw user-entered location query (zip/city/state text). */
  locationInput String?
  /** Normalized display string (e.g. "Roanoke, VA"). */
  locationDisplay String?
  locationZip     String?
  locationCity    String?
  /** US county name (if resolved). */
  locationCounty  String?
  /** US state code/name (e.g. "VA"). */
  locationState   String?
  /** Country code/name; US only for now. */
  locationCountry String?
  // Required onboarding fields (gates app access).
  // Stored as DateTime (UTC midnight) to keep Prisma portable.
  birthdate DateTime?
  interests String[] @default([])
  // Required onboarding acknowledgement (app store friendly wording; enforced in app).
  menOnlyConfirmed Boolean @default(false)
  // True when the user has explicitly chosen a username.
  usernameIsSet Boolean @default(false)
  // Minimal admin flag (will be replaced by real roles later).
  siteAdmin Boolean @default(false)
  // App entrypoint/feature switches controlled by admins (e.g., "articles").
  featureToggles String[] @default([])
  // Account state: banned users cannot log in (sessions revoked) and should see a clear message.
  bannedAt DateTime?
  bannedReason String?
  bannedByAdminId String?
  // Premium flag (paid product access; used for visibility gating). Computed by EntitlementService.
  premium Boolean @default(false)
  // Premium+ (superset of premium; special supporters tier). Computed by EntitlementService.
  premiumPlus Boolean @default(false)
  // Organization account (special badge + avatar shape in clients).
  isOrganization Boolean @default(false)
  // Premium+ opt-in steward badge shown across the app.
  stewardBadgeEnabled Boolean @default(true)
  // Verified badge (more roles/permissions later).
  verifiedStatus VerifiedStatus @default(none)
  verifiedAt DateTime?
  unverifiedAt DateTime?
  // Stripe billing identifiers (optional; null when user has never subscribed).
  stripeCustomerId String? @unique
  stripeSubscriptionId String? @unique
  stripeSubscriptionStatus String?
  stripeSubscriptionPriceId String?
  stripeCurrentPeriodStart DateTime?
  stripeCurrentPeriodEnd DateTime?
  stripeCancelAtPeriodEnd Boolean @default(false)
  // Follow list privacy (controls counts + follower/following lists).
  followVisibility FollowVisibility @default(all)
  // Birthday privacy/display preference for public profile.
  birthdayVisibility BirthdayVisibility @default(monthDay)
  // Public media (stored in object storage; API stores keys only).
  avatarKey String?
  avatarUpdatedAt DateTime?
  bannerKey String?
  bannerUpdatedAt DateTime?
  /** Override bio shown in the author section at the bottom of articles. Uses regular bio if null. */
  articleBio String?
  // When the user last went offline (set by presence disconnect).
  lastOnlineAt DateTime?
  // When the user last had in-app activity (presence connect/ping). Used for DAU/MAU.
  lastSeenAt DateTime?
  // Denormalized badge count for notifications where deliveredAt is still null.
  // Maintained atomically in NotificationsService.
  undeliveredNotificationCount Int @default(0)

  // Private rewards / retention loops (self-only surfaces).
  coins Int @default(0)
  /** Current consecutive-day check-in streak (ET day key boundaries). */
  checkinStreakDays Int @default(0)
  /** Last ET day key the user checked in (YYYY-MM-DD). */
  lastCheckinDayKey String?
  /** Longest streak achieved (private). */
  longestStreakDays Int @default(0)
  /** One-time profile reminder email sent at ~24h after signup. */
  profileReminder24hSentAt DateTime?
  /** One-time profile reminder email sent at ~7d after signup. */
  profileReminder7dSentAt DateTime?
  dailyActivityDays UserDailyActivity[]
  sessions  Session[]
  posts     Post[]
  boosts    Boost[]
  pollVotes PostPollVote[]
  bookmarks Bookmark[]
  bookmarkCollections BookmarkCollection[]
  // Pinned post on profile (one per user; must be own post).
  pinnedPostId String? @unique
  pinnedPost   Post?   @relation("PinnedPost", fields: [pinnedPostId], references: [id], onDelete: SetNull)

  // Social graph (self-referential via Follow).
  // `following`: users this user follows (outgoing edges)
  // `followers`: users who follow this user (incoming edges)
  following Follow[] @relation("Follow_follower")
  followers Follow[] @relation("Follow_following")
  topicFollows TopicFollow[]

  // Admin audit relations
  deletedPostMedia PostMedia[] @relation("PostMedia_deletedByAdmin")
  deletedMediaAssets MediaAsset[] @relation("MediaAsset_deletedByAdmin")
  mentionedIn PostMention[] @relation("PostMention_user")
  notificationsReceived Notification[] @relation("Notification_recipient")
  notificationsAsActor Notification[] @relation("Notification_actor")
  notificationsAsSubjectUser Notification[] @relation("Notification_subjectUser")
  pushSubscriptions PushSubscription[]
  notificationPreferences NotificationPreferences?
  articleTagPreferences UserArticleTagPreference[]
  taxonomyPreferences UserTaxonomyPreference[]
  pushCoalesces PushCoalesce[]
  userSearches     UserSearch[]
  feedbacks        Feedback[]
  reportsMade      Report[] @relation("Report_reporter")
  reportsReceived  Report[] @relation("Report_subjectUser")
  reportsResolved  Report[] @relation("Report_resolvedBy")
  verificationRequests VerificationRequest[] @relation("VerificationRequest_user")
  verificationRequestsReviewed VerificationRequest[] @relation("VerificationRequest_reviewedBy")
  emailActionTokens EmailActionToken[]
  subscriptionGrants SubscriptionGrant[] @relation("SubscriptionGrant_user")
  subscriptionGrantsGiven SubscriptionGrant[] @relation("SubscriptionGrant_grantedByAdmin")
  messageParticipants MessageParticipant[] @relation("MessageParticipant_user")
  messagesSent        Message[] @relation("Message_sender")
  messageConversationsCreated MessageConversation[] @relation("MessageConversation_createdBy")
  messageReactions    MessageReaction[] @relation("MessageReaction_user")
  messageDeletions    MessageDeletion[] @relation("MessageDeletion_user")
  blocksInitiated UserBlock[] @relation("UserBlock_blocker")
  blocksReceived  UserBlock[] @relation("UserBlock_blocked")
  postViews    PostView[]
  viewerIdentities ViewerIdentity[]
  articleViews ArticleView[]
  articles  Article[]
  articleBoosts ArticleBoost[]
  articleReactions ArticleReaction[]
  articleComments ArticleComment[]
  articleCommentReactions ArticleCommentReaction[]

  // Org affiliations: orgs this user belongs to (non-org users); members of this org (org users).
  orgMemberships UserOrgMembership[] @relation("UserMemberships")
  orgMembers     UserOrgMembership[] @relation("OrgMembers")

  coinTransfersSent     CoinTransfer[] @relation("CoinTransfer_sender")
  coinTransfersReceived CoinTransfer[] @relation("CoinTransfer_recipient")

  communityGroupsCreated CommunityGroup[] @relation("CommunityGroup_createdBy")
  communityGroupMemberships CommunityGroupMember[]
  communityGroupInvitesSent     CommunityGroupInvite[] @relation("CommunityGroupInvite_invitedBy")
  communityGroupInvitesReceived CommunityGroupInvite[] @relation("CommunityGroupInvite_invitee")

  crewsOwned              Crew[]                 @relation("Crew_owner")
  crewsDesignatedSuccessorOf Crew[]              @relation("Crew_designatedSuccessor")
  crewMembership          CrewMember?            @relation("CrewMember_user")
  crewInvitesSent         CrewInvite[]           @relation("CrewInvite_invitedBy")
  crewInvitesReceived     CrewInvite[]           @relation("CrewInvite_invitee")
  crewTransferVotesProposed CrewOwnerTransferVote[] @relation("CrewOwnerTransferVote_proposer")
  crewTransferVotesTargeting CrewOwnerTransferVote[] @relation("CrewOwnerTransferVote_target")
  crewTransferBallots     CrewOwnerTransferBallot[] @relation("CrewOwnerTransferBallot_user")

  space Space?

  // Referral / recruitment
  /** Unique promo code set by this user (premium-only). Others use this to mark this user as their recruiter. */
  referralCode        String?   @unique
  /** The user who recruited this user (set once via a referral code; immutable after set). */
  recruitedById       String?
  recruitedBy         User?     @relation("Recruitment_recruiter", fields: [recruitedById], references: [id], onDelete: SetNull)
  recruits            User[]    @relation("Recruitment_recruiter")
  /** When the one-time referral bonus grant was issued (null = not yet triggered). */
  referralBonusGrantedAt DateTime?

  @@index([phone])
  @@index([lastSeenAt])
  @@index([referralCode])
  @@index([recruitedById])
  // Leaderboard queries: sort by active streak then longest streak, filter by bannedAt IS NULL.
  @@index([bannedAt, checkinStreakDays(sort: Desc), longestStreakDays(sort: Desc), createdAt(sort: Asc)])
}

model UserOrgMembership {
  userId    String
  orgId     String
  createdAt DateTime @default(now())

  user User @relation("UserMemberships", fields: [userId], references: [id], onDelete: Cascade)
  org  User @relation("OrgMembers", fields: [orgId], references: [id], onDelete: Cascade)

  @@id([userId, orgId])
  @@index([orgId])
  @@index([userId, createdAt])
}

model EmailActionToken {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  purpose   EmailActionTokenPurpose
  tokenHash String   @unique
  /** Optional snapshot of email the action was created for (helps invalidate on email change). */
  email     String?
  expiresAt DateTime
  consumedAt DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, purpose, createdAt])
  @@index([expiresAt])
  @@index([consumedAt])
}

model DailyContentSnapshot {
  /** Eastern Time day key (YYYY-MM-DD). */
  dayKey String @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  quote Json?
  quoteRefreshedAt DateTime?

  websters1828 Json?
  websters1828RefreshedAt DateTime?
  websters1828RecheckedAt DateTime?

  @@index([updatedAt])
}

/**
 * Stripe webhook event dedupe (Stripe may retry; we must be idempotent).
 * Use the Stripe event id as the primary key.
 */
model StripeWebhookEvent {
  id        String   @id
  createdAt DateTime @default(now())

  @@index([createdAt])
}

/**
 * Time-boxed premium entitlement grant (admin comp, future referral rewards, etc.).
 * Grants stack: the latest active endsAt determines effective access window.
 * source=admin: created by a site admin; source=referral: future automated rewards.
 */
model SubscriptionGrant {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId String
  user   User   @relation("SubscriptionGrant_user", fields: [userId], references: [id], onDelete: Cascade)

  tier   SubscriptionGrantTier
  source SubscriptionGrantSource

  /** Number of months this grant covers. */
  months Int

  startsAt DateTime
  endsAt   DateTime

  /** Optional internal note (reason for the grant). */
  reason String? @db.Text

  /** Admin who created this grant (null for automated sources). */
  grantedByAdminId String?
  grantedByAdmin   User?   @relation("SubscriptionGrant_grantedByAdmin", fields: [grantedByAdminId], references: [id], onDelete: SetNull)

  /** Set when an admin revokes the grant early (null = still active). */
  revokedAt DateTime?

  /**
   * When true, this grant only counts towards entitlement while the user has an active Stripe
   * subscription. Used for referral grants so free months don't drain without a paid plan.
   * Admin grants always apply regardless, so they default to false.
   */
  requiresActiveSubscription Boolean @default(false)

  @@index([userId, endsAt])
  @@index([userId, revokedAt, endsAt])
  @@index([createdAt])
}

/**
 * Per-user per-day activity rollup (UTC day).
 * This exists so we can compute historical DAU averages (a single lastSeenAt cannot).
 */
model UserDailyActivity {
  userId    String
  /** UTC midnight for the day this activity represents. */
  day       DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, day])
  @@index([day])
}

model UserSearch {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  query     String   @db.VarChar(200)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([query])
}

model PushSubscription {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  userId   String
  endpoint String   @db.Text
  p256dh   String   @db.Text
  auth     String   @db.Text
  userAgent String? @db.Text

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, endpoint])
  @@index([userId])
}

model Follow {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  followerId  String
  followingId String

  /** When true, viewer receives “every post” notifications (bell icon enabled). */
  postNotificationsEnabled Boolean @default(false)

  follower  User @relation("Follow_follower", fields: [followerId], references: [id], onDelete: Cascade)
  following User @relation("Follow_following", fields: [followingId], references: [id], onDelete: Cascade)

  @@unique([followerId, followingId])
  @@index([followerId, createdAt])
  @@index([followingId, createdAt])
  // Speeds up mutual/friends-of-friends queries that walk edges in reverse.
  @@index([followingId, followerId])
}

model TopicFollow {
  createdAt DateTime @default(now())

  userId String
  /** Canonical topic value (must be in allowlist). */
  topic  String @db.VarChar(64)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, topic])
  @@index([userId, createdAt])
  @@index([topic, createdAt])
}

/**
 * Public community group (distinct from MessageConversationType.group DMs).
 * Shell metadata is visible to signed-in users; posts with communityGroupId are members-only.
 */
model CommunityGroup {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  deletedAt DateTime?

  slug        String  @unique @db.VarChar(80)
  name        String  @db.VarChar(120)
  description String  @db.Text
  rules       String? @db.Text
  coverImageUrl String? @db.VarChar(2000)
  /** Square group avatar (URL), distinct from wide cover/banner. */
  avatarImageUrl String? @db.VarChar(2000)

  joinPolicy CommunityGroupJoinPolicy @default(open)

  createdByUserId String
  createdBy       User   @relation("CommunityGroup_createdBy", fields: [createdByUserId], references: [id], onDelete: Restrict)

  /** Curated discovery ordering; only meaningful when isFeatured is true. */
  isFeatured     Boolean @default(false)
  featuredOrder  Int     @default(0)
  /** Denormalized count of active members (updated on join/leave/approve). */
  memberCount    Int     @default(0)

  members       CommunityGroupMember[]
  invites       CommunityGroupInvite[]
  posts         Post[]
  notifications Notification[] @relation("Notification_subjectGroup")

  @@index([deletedAt, isFeatured, featuredOrder])
  @@index([createdAt])
}

model CommunityGroupMember {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId String
  group   CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  role   CommunityGroupMemberRole
  status CommunityGroupMemberStatus

  @@id([groupId, userId])
  @@index([userId, status])
  @@index([groupId, status])
}

/**
 * Owner/moderator-issued invitation for a user to join a CommunityGroup.
 *
 * Lifecycle:
 *   - `pending`   — issued, awaiting invitee response. Re-invites of the same
 *     (groupId, inviteeUserId) reuse this row; we only re-notify the invitee
 *     after `GROUP_INVITE_RENOTIFY_AFTER_HOURS` of silence.
 *   - `accepted`  — invitee joined. If they later leave, a fresh invite can be
 *     created (the prior row remains for history).
 *   - `declined`  — invitee rejected. Re-inviting before
 *     `GROUP_INVITE_REINVITE_AFTER_DECLINE_DAYS` is forbidden; afterward the
 *     row is reset back to `pending` and `lastDeclinedAt` is preserved so the
 *     inviter's UI can still show "previously declined".
 *   - `cancelled` — pulled by the inviter (or any owner/mod).
 *   - `expired`   — flipped by an expiry job after `expiresAt`.
 *
 * Uniqueness on `[groupId, inviteeUserId]` means there's at most one invite
 * row per (group, invitee) — re-invites mutate this row in place.
 */
model CommunityGroupInvite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  groupId String
  group   CommunityGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation("CommunityGroupInvite_invitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  inviteeUserId String
  invitee       User   @relation("CommunityGroupInvite_invitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  /** Optional short note from the inviter (shown to the invitee on the row + push body). */
  message String? @db.VarChar(500)

  status CommunityGroupInviteStatus @default(pending)

  /** Default expiry is 30 days after most-recent (re)issue; refreshed on re-invite. */
  expiresAt DateTime

  /** When the most recent push/in-app notification was sent for this invite. Used for re-notify cooldown. */
  lastNotifiedAt DateTime?

  /** When the invitee last declined. Preserved across re-invites for the picker UI hint. */
  lastDeclinedAt DateTime?

  /** Timestamp of the most recent terminal transition (accepted/declined/cancelled/expired). */
  respondedAt DateTime?

  notifications Notification[] @relation("Notification_subjectCommunityGroupInvite")

  @@unique([groupId, inviteeUserId])
  @@index([inviteeUserId, status, createdAt])
  @@index([invitedByUserId, status, createdAt])
  @@index([groupId, status, createdAt])
  @@index([status, expiresAt])
}

/**
 * A Crew is a hard-capped (5), invite-only squad. Each user may belong to at most one crew
 * (enforced via a UNIQUE on CrewMember.userId). The owner manages invites, membership, and
 * crew metadata. Every crew has an auto-created MessageConversation (type: crew_wall) which
 * backs "The Wall" (persistent chat-like posting inside the crew).
 *
 * Public pages at /c/:slug are always available (display "Untitled Crew" if `name` is null).
 * The wall + member list + settings are private to crew members.
 */
model Crew {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  /** Soft delete (disbanded). Preserves history without orphaning references. */
  deletedAt DateTime?

  /** URL slug for the public crew page (/c/:slug). Auto-generated, regenerated on rename. */
  slug String @unique @db.VarChar(80)

  /** Optional crew name. When null, public pages render "Untitled Crew". */
  name    String? @db.VarChar(120)
  tagline String? @db.VarChar(160)
  bio     String? @db.Text

  /** Square avatar (R2 key or URL). Displayed on the public page and on member profiles. */
  avatarImageUrl String? @db.VarChar(2000)
  /** Wide banner on the public page. */
  coverImageUrl  String? @db.VarChar(2000)

  ownerUserId String
  owner       User   @relation("Crew_owner", fields: [ownerUserId], references: [id], onDelete: Restrict)

  /**
   * Designated successor (a non-owner member). Used by the 30-day-inactive auto-transfer job.
   * Null means "fall back to the longest-tenured non-owner member".
   */
  designatedSuccessorUserId String?
  designatedSuccessor       User?   @relation("Crew_designatedSuccessor", fields: [designatedSuccessorUserId], references: [id], onDelete: SetNull)

  /**
   * MessageConversation (type: crew_wall) backing The Wall. Created atomically with the crew.
   * Participants mirror CrewMember (owner = conversation owner; members = conversation members).
   */
  wallConversationId String              @unique
  wallConversation   MessageConversation @relation("Crew_wallConversation", fields: [wallConversationId], references: [id], onDelete: Restrict)

  /** Denormalized count of CrewMember rows. Updated atomically on join/kick/leave. */
  memberCount Int @default(1)

  /**
   * Strict crew streak: a day only counts when EVERY member checks in by ET midnight.
   * One absentee breaks the streak. Stored denormalized so we never have to scan history.
   *
   * - currentStreakDays: the active run length (resets to 0 on a missed day).
   * - longestStreakDays: best run ever achieved by this crew.
   * - lastCompletedDayKey: ET YYYY-MM-DD for the most recent day all members checked in.
   *   Used both to advance (todayKey) and to detect breaks (yesterdayKey) in the cron.
   */
  currentStreakDays   Int     @default(0)
  longestStreakDays   Int     @default(0)
  lastCompletedDayKey String?

  members CrewMember[]
  invites CrewInvite[]
  transferVotes CrewOwnerTransferVote[] @relation("CrewOwnerTransferVote_crew")
  notifications Notification[] @relation("Notification_subjectCrew")

  /**
   * If an old slug exists, we redirect to the current slug.
   * (see CrewSlugHistory below)
   */
  slugHistory CrewSlugHistory[]

  @@index([deletedAt, createdAt])
  @@index([ownerUserId])
}

/**
 * Tracks historical slugs for a crew so renames can 301 from the old /c/:oldSlug.
 * Each historic slug is globally unique (cannot collide with an active crew slug).
 */
model CrewSlugHistory {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  slug   String @unique @db.VarChar(80)
  crewId String
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)

  @@index([crewId, createdAt])
}

model CrewMember {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crewId String
  crew   Crew   @relation(fields: [crewId], references: [id], onDelete: Cascade)

  /**
   * Enforces the "one crew per user" rule at the DB level. Attempting to join a second
   * crew will surface a Prisma unique constraint error the service translates into a
   * 409 Conflict with a friendly message.
   */
  userId String @unique
  user   User   @relation("CrewMember_user", fields: [userId], references: [id], onDelete: Cascade)

  role      CrewMemberRole @default(member)
  /** Owner-controlled display order (0 = first). Ties are broken by joinedAt (createdAt) ascending. */
  sortOrder Int            @default(0)

  @@id([crewId, userId])
  @@index([crewId, role])
  @@index([crewId, createdAt])
  @@index([crewId, sortOrder, createdAt])
}

/**
 * Crew invite lifecycle:
 *   - Founding invite: `crewId` is NULL (the inviter has no crew yet). The first accepted
 *     founding invite creates the crew and auto-cancels the inviter's other pending
 *     founding invites (they re-target the new crew as regular invites if the inviter chooses).
 *   - Regular invite: `crewId` is set (the inviter is already the owner of that crew).
 *
 * Only the owner of an existing crew may send regular invites. Crewless users may send
 * founding invites. Invites expire after 14 days (enforced by a periodic job that flips
 * status from pending -> expired).
 */
model CrewInvite {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  /**
   * Null for a "founding invite" sent by a user who does not yet own a crew. Set for
   * regular invites sent by an existing crew owner.
   */
  crewId String?
  crew   Crew?  @relation(fields: [crewId], references: [id], onDelete: Cascade)

  invitedByUserId String
  invitedBy       User   @relation("CrewInvite_invitedBy", fields: [invitedByUserId], references: [id], onDelete: Cascade)

  inviteeUserId String
  invitee       User   @relation("CrewInvite_invitee", fields: [inviteeUserId], references: [id], onDelete: Cascade)

  /** Optional short message from the inviter (shown to the invitee). */
  message String? @db.VarChar(500)

  /**
   * Name to use when the crew is *created* on first acceptance of a founding
   * invite. Ignored for invites that already have a non-null `crewId` (the crew
   * is already named via `Crew.name`).
   */
  crewNameOnAccept String? @db.VarChar(80)

  status CrewInviteStatus @default(pending)

  /** 14 days after createdAt by default; enforced by expiry job. */
  expiresAt DateTime

  /** Timestamp of the terminal state transition (accepted/declined/cancelled/expired). */
  respondedAt DateTime?

  notifications Notification[] @relation("Notification_subjectCrewInvite")

  @@index([inviteeUserId, status, createdAt])
  @@index([invitedByUserId, status, createdAt])
  @@index([crewId, status, createdAt])
  @@index([status, expiresAt])
}

/**
 * Owner transfer vote: non-owner crew members may unanimously vote to transfer ownership
 * (to a specific target member, typically the proposer or a designated successor).
 * A vote requires ALL non-owner members to cast a ballot of `inFavor = true` to pass.
 * A single ballot of `inFavor = false` (or a withdrawn ballot) invalidates the vote.
 */
model CrewOwnerTransferVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  crewId String
  crew   Crew   @relation("CrewOwnerTransferVote_crew", fields: [crewId], references: [id], onDelete: Cascade)

  proposerUserId String
  proposer       User   @relation("CrewOwnerTransferVote_proposer", fields: [proposerUserId], references: [id], onDelete: Cascade)

  /** The member proposed to become the new owner. */
  targetUserId String
  target       User   @relation("CrewOwnerTransferVote_target", fields: [targetUserId], references: [id], onDelete: Cascade)

  /**
   * Lifecycle: open (collecting ballots) -> passed (all non-owner members voted yes) |
   * rejected (any non-owner voted no) | cancelled (proposer withdrew) | expired (time limit).
   */
  status String @default("open") @db.VarChar(20)

  /** Soft deadline for the vote (default 7 days). After this the job marks it expired. */
  expiresAt DateTime

  resolvedAt DateTime?

  ballots CrewOwnerTransferBallot[]

  @@index([crewId, status])
  @@index([status, expiresAt])
}

model CrewOwnerTransferBallot {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  voteId String
  vote   CrewOwnerTransferVote @relation(fields: [voteId], references: [id], onDelete: Cascade)

  userId String
  user   User   @relation("CrewOwnerTransferBallot_user", fields: [userId], references: [id], onDelete: Cascade)

  inFavor Boolean

  @@id([voteId, userId])
  @@index([userId, updatedAt])
}

model Space {
  id          String    @id @default(cuid())
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  ownerId     String    @unique
  owner       User      @relation(fields: [ownerId], references: [id], onDelete: Cascade)

  title       String    @db.VarChar(100)
  description String?   @db.VarChar(500)

  isActive    Boolean   @default(false)

  mode            SpaceMode @default(NONE)
  watchPartyUrl   String?   @db.VarChar(2000)
  radioStreamUrl  String?   @db.VarChar(2000)

  @@index([isActive])
}

model Post {
  id         String         @id @default(cuid())
  createdAt  DateTime       @default(now())
  editedAt   DateTime?
  editCount  Int            @default(0)
  deletedAt  DateTime?
  body       String
  /** Drafts are only-me posts used for autosave / compose. */
  isDraft    Boolean        @default(false)
  /** Inferred topics (from allowlist) used for search/discovery. */
  topics     String[]       @default([])
  /** User-created hashtags (parsed from body) used for search/autocomplete. Stored lowercase. */
  hashtags   String[]       @default([])
  /** Hashtag casing variants used in this post (one per entry in `hashtags`, without '#'). */
  hashtagCasings String[]   @default([])
  kind       PostKind       @default(regular)
  /** ET day key (YYYY-MM-DD) for check-ins (null for non-check-ins). */
  checkinDayKey String?
  /** Prompt text used for this check-in day (stored to keep history stable). */
  checkinPrompt String?
  visibility PostVisibility @default(public)
  boostCount Int            @default(0)
  bookmarkCount Int         @default(0)
  commentCount Int          @default(0)
  /** Denormalized count of flat reposts + quote reposts referencing this post. */
  repostCount Int           @default(0)
  viewerCount Int            @default(0)
  weightedViewCount Float    @default(0)
  boostScore Float?
  boostScoreUpdatedAt DateTime?
  /** Precomputed trending score, refreshed every ~10 min by the popular-score cron. NULL = not yet scored. */
  trendingScore Float?
  trendingScoreUpdatedAt DateTime?

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  /** When set, post belongs to a community group and must not appear on global feeds. */
  communityGroupId String?
  communityGroup   CommunityGroup? @relation(fields: [communityGroupId], references: [id], onDelete: Cascade)
  /** Owner-pinned root post in this group (at most one per group). */
  pinnedInGroupAt DateTime?

  parentId String?
  parent   Post?   @relation("Post_replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  Post[] @relation("Post_replies")

  // Root post ID for thread hierarchy (null for root posts, set to root post ID for all replies in a thread)
  rootId String?
  root   Post?   @relation("Post_thread", fields: [rootId], references: [id], onDelete: Cascade)
  threadReplies Post[] @relation("Post_thread")

  // Flat repost: points to the original post being reshared (kind=repost only).
  repostedPostId String?
  repostedPost   Post?   @relation("Post_reposts", fields: [repostedPostId], references: [id], onDelete: Cascade)
  reposts        Post[]  @relation("Post_reposts")

  // Article share: points to the article being shared (kind=articleShare only).
  articleId String?
  article   Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  // Quote repost: the embedded post whose URL was detected in body on save.
  quotedPostId String?
  quotedPost   Post?   @relation("Post_quotes", fields: [quotedPostId], references: [id], onDelete: SetNull)
  quotes       Post[]  @relation("Post_quotes")

  boosts   Boost[]
  media    PostMedia[]
  poll     PostPoll?
  bookmarks Bookmark[]
  mentions PostMention[]
  versions PostVersion[]
  anonViews PostAnonView[]
  pinnedByUser User? @relation("PinnedPost")
  notificationsAsSubject Notification[] @relation("Notification_subjectPost")
  notificationsAsActorPost Notification[] @relation("Notification_actorPost")
  reports Report[] @relation("Report_subjectPost")
  views PostView[]

  @@index([userId, createdAt])
  @@index([createdAt])
  @@index([kind, createdAt])
  @@unique([userId, kind, checkinDayKey])
  @@index([parentId])
  @@index([parentId, createdAt])
  @@index([rootId])
  @@index([rootId, createdAt])
  @@index([repostedPostId])
  @@index([repostedPostId, userId])
  @@index([quotedPostId])
  @@index([articleId])
  @@index([topics], type: Gin)
  @@index([hashtags], type: Gin)
  // Feed/trending hot paths (parentId IS NULL + deletedAt IS NULL) benefit from composite indexes matching sort+filters.
  @@index([parentId, deletedAt, createdAt(sort: Desc), id(sort: Desc)])
  @@index([parentId, deletedAt, boostCount(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@index([parentId, deletedAt, bookmarkCount(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  // Trending feed hot path: sort by precomputed score descending.
  @@index([trendingScore(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@index([parentId, deletedAt, commentCount(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  // New feed (sort=new) hot path: deleted + visibility filter + createdAt/id pagination.
  @@index([deletedAt, visibility, createdAt(sort: Desc), id(sort: Desc)])
  // Profile posts/replies hot path: user + deleted + visibility + createdAt/id pagination.
  @@index([userId, deletedAt, visibility, createdAt(sort: Desc), id(sort: Desc)])
  // Profile top-level tab: same as above, plus parentId NULL filter.
  @@index([userId, parentId, deletedAt, visibility, createdAt(sort: Desc), id(sort: Desc)])
  // Trending feed path with visibility gating.
  @@index([deletedAt, visibility, trendingScore(sort: Desc), createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityGroupId, deletedAt, createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityGroupId, parentId, deletedAt, createdAt(sort: Desc), id(sort: Desc)])
  @@index([communityGroupId, pinnedInGroupAt])
}

model PostPoll {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  /** Poll end timestamp (UTC). */
  endsAt    DateTime
  totalVoteCount Int @default(0)
  /** When set, "poll results ready" notifications have been created. */
  resultsNotifiedAt DateTime?
  /** When set, the poll creator chose to skip voting (see results without casting a vote). */
  creatorSkippedAt DateTime?

  postId String @unique
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  options PostPollOption[]
  votes   PostPollVote[]

  @@index([endsAt])
  @@index([resultsNotifiedAt])
  @@index([createdAt])
}

model PostPollOption {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  pollId String
  poll   PostPoll @relation(fields: [pollId], references: [id], onDelete: Cascade)

  text     String @db.VarChar(30)
  position Int    @default(0)

  /** Optional image (stored in R2; URL computed server-side from base URL). */
  imageR2Key String?
  imageWidth Int?
  imageHeight Int?
  imageAlt   String? @db.VarChar(500)

  voteCount Int @default(0)
  votes     PostPollVote[]

  @@unique([pollId, position])
  @@index([pollId, position])
}

model PostPollVote {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  pollId   String
  optionId String
  userId   String

  poll   PostPoll       @relation(fields: [pollId], references: [id], onDelete: Cascade)
  option PostPollOption @relation(fields: [optionId], references: [id], onDelete: Cascade)
  user   User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([pollId, userId])
  @@index([pollId, createdAt])
  @@index([optionId, createdAt])
  @@index([userId, createdAt])
}

model PostVersion {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  postId String
  post   Post   @relation(fields: [postId], references: [id], onDelete: Cascade)

  body String
  topics String[] @default([])
  hashtags String[] @default([])
  hashtagCasings String[] @default([])
  visibility PostVisibility

  @@index([postId, createdAt])
}

model Hashtag {
  tag String @id

  usageCount Int @default(0)
  /** Most common casing for display/autocomplete, e.g. "HashTags". */
  displayTag String?
  /** Count for `displayTag` (ties keep existing). */
  displayTagCount Int @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  variants HashtagVariant[]

  @@index([usageCount])
  @@index([updatedAt])
}

model HashtagVariant {
  tag     String
  variant String
  count   Int @default(0)

  hashtag Hashtag @relation(fields: [tag], references: [tag], onDelete: Cascade)

  @@id([tag, variant])
  @@index([tag])
  @@index([count])
}

model HashtagBackfillRun {
  id String @id @default(cuid())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  status String @default("running")
  /** Post id cursor for createdAt/id pagination. */
  cursor String?
  processedPosts Int @default(0)
  updatedPosts Int @default(0)
  resetDone Boolean @default(false)
  startedAt DateTime @default(now())
  finishedAt DateTime?
  lastError String? @db.Text

  @@index([status, updatedAt])
}

// Postgres-backed "cache": periodic snapshots of trending hashtag scores.
// We keep a small rolling window (e.g. last ~1 hour) so paging remains stable across refreshes.
model HashtagTrendingScoreSnapshot {
  asOf DateTime
  /** Canonical lowercase tag (no '#'). */
  tag String
  visibility PostVisibility
  /** Time-decayed score (half-life based); used for ranking only. */
  score Float
  /** Raw usage count within the lookback window (not time-decayed). */
  usageCount Int

  @@id([asOf, visibility, tag])
  @@index([asOf, visibility, score(sort: Desc), usageCount(sort: Desc), tag(sort: Asc)])
  @@index([asOf, tag])
}

model PostMention {
  postId String
  userId String

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)
  user User @relation("PostMention_user", fields: [userId], references: [id], onDelete: Cascade)

  @@id([postId, userId])
  @@index([userId])
}

model BookmarkCollection {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  name String
  slug String

  userId String
  user   User @relation(fields: [userId], references: [id], onDelete: Cascade)

  bookmarks BookmarkCollectionItem[]

  @@unique([userId, name])
  @@unique([userId, slug])
  @@index([userId, createdAt])
}

model Bookmark {

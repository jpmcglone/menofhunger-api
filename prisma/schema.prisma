  @@index([phone, createdAt])
  @@index([expiresAt])
}

model Session {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  expiresAt DateTime
  revokedAt DateTime?
  tokenHash String    @unique

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
}

model Notification {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  deliveredAt DateTime?
  readAt    DateTime?
  ignoredAt DateTime?
  nudgedBackAt DateTime?

  recipientUserId String
  kind      NotificationKind
  actorUserId    String?
  /** The post that caused this notification (e.g. a reply or a mention post). */
  actorPostId    String?
  subjectPostId  String?
  subjectUserId  String?
  subjectArticleId String?
  subjectArticleCommentId String?
  subjectGroupId   String?
  subjectCrewId    String?
  /**
   * Specific crew invite this notification refers to. Lets the notification UI
   * accept/decline the exact invite without resolving by (actor, recipient) pair.
   * SetNull on delete so notifications survive invite cleanup.
   */
  subjectCrewInviteId String?
  /**
   * Specific community group invite this notification refers to. Mirrors the
   * crew invite pattern so the notification UI can accept/decline the exact
   * invite without an extra round-trip.
   */
  subjectCommunityGroupInviteId String?
  /**
   * Conversation this notification is about (used for `message` kind).
   * SetNull on delete so the notification survives conversation cleanup.
   */
  subjectConversationId String?
  title     String?
  body      String?

  recipient User  @relation("Notification_recipient", fields: [recipientUserId], references: [id], onDelete: Cascade)
  actor     User? @relation("Notification_actor", fields: [actorUserId], references: [id], onDelete: SetNull)
  actorPost Post? @relation("Notification_actorPost", fields: [actorPostId], references: [id], onDelete: SetNull)
  subjectPost Post? @relation("Notification_subjectPost", fields: [subjectPostId], references: [id], onDelete: SetNull)
  subjectUser User? @relation("Notification_subjectUser", fields: [subjectUserId], references: [id], onDelete: SetNull)
  subjectArticle Article? @relation("Notification_subjectArticle", fields: [subjectArticleId], references: [id], onDelete: SetNull)
  subjectArticleComment ArticleComment? @relation("Notification_subjectArticleComment", fields: [subjectArticleCommentId], references: [id], onDelete: SetNull)
  subjectGroup CommunityGroup? @relation("Notification_subjectGroup", fields: [subjectGroupId], references: [id], onDelete: SetNull)
  subjectCrew  Crew?           @relation("Notification_subjectCrew", fields: [subjectCrewId], references: [id], onDelete: SetNull)
  subjectCrewInvite CrewInvite? @relation("Notification_subjectCrewInvite", fields: [subjectCrewInviteId], references: [id], onDelete: SetNull)
  subjectCommunityGroupInvite CommunityGroupInvite? @relation("Notification_subjectCommunityGroupInvite", fields: [subjectCommunityGroupInviteId], references: [id], onDelete: SetNull)
  subjectConversation MessageConversation? @relation("Notification_subjectConversation", fields: [subjectConversationId], references: [id], onDelete: SetNull)

  @@index([recipientUserId, createdAt])
  @@index([recipientUserId, deliveredAt])
  @@index([recipientUserId, readAt])
  @@index([recipientUserId, ignoredAt])
  @@index([recipientUserId, nudgedBackAt])
  @@index([actorPostId])
  @@index([subjectPostId])
  @@index([subjectArticleId])
  // Common list ordering/pagination: ORDER BY createdAt DESC, id DESC.
  @@index([recipientUserId, createdAt(sort: Desc), id(sort: Desc)])
}

model NotificationPreferences {
  userId    String   @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // Web push preferences (in-app notifications are always created; this controls browser notifications).
  pushComment Boolean @default(true)
  pushBoost Boolean @default(true)
  pushFollow Boolean @default(true)
  pushMention Boolean @default(true)
  pushMessage Boolean @default(true)
  pushRepost Boolean @default(true)
  pushNudge Boolean @default(true)
  pushFollowedPost Boolean @default(true)
  /** Send a single push 24h after a reply if the recipient hasn't opened it yet. Once-per-notification, never spammed. */
  pushReplyNudge Boolean @default(true)
  /** Crew streak: push when the strict crew streak advances or breaks. Highest-signal push in the product. */
  pushCrewStreak Boolean @default(true)
  /** Group activity: push for join, approve/reject, remove, disband events. */
  pushGroupActivity Boolean @default(true)

  // Email preferences (requires user.email).
  emailDigestDaily Boolean @default(true)
  emailDigestWeekly Boolean @default(true)
  emailNewNotifications Boolean @default(true)
  /** Optional: send near-immediate emails for high-signal events (messages + mentions/replies). */
  emailInstantHighSignal Boolean @default(true)
  /** Send a reminder email if you're at risk of losing your streak today. */
  emailStreakReminder Boolean @default(true)
  /** Send an email when someone you follow publishes a new article. */
  emailFollowedArticle Boolean @default(true)

  // Email send timestamps (rate limiting / dedupe).
  lastEmailDigestDailySentAt DateTime?
  lastEmailDigestWeeklySentAt DateTime?
  lastEmailNewNotificationsSentAt DateTime?
  lastEmailInstantHighSignalSentAt DateTime?
  lastEmailStreakReminderSentAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([updatedAt])
  @@index([lastEmailNewNotificationsSentAt])
  @@index([lastEmailDigestDailySentAt])
  @@index([lastEmailInstantHighSignalSentAt])
  @@index([lastEmailStreakReminderSentAt])
}

model UserArticleTagPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  /** Normalized tag slug (lowercase, alphanumeric + hyphens). */
  tag       String
  /** Display label for UI/email sections. */
  label     String

  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, tag])
  @@index([userId])
  @@index([tag])
}

model TaxonomyTerm {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  slug   String
  label  String
  kind   TaxonomyTermKind
  status TaxonomyTermStatus @default(active)

  aliases TaxonomyAlias[]
  outgoingEdges TaxonomyEdge[] @relation("TaxonomyEdge_from")
  incomingEdges TaxonomyEdge[] @relation("TaxonomyEdge_to")
  userPreferences UserTaxonomyPreference[]
  metrics TaxonomyTermMetric?

  @@unique([slug])
  @@index([kind, status])
}

model TaxonomyAlias {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  alias  String
  source TaxonomyAliasSource

  termId String
  term   TaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([alias])
  @@index([termId, source])
}

model TaxonomyEdge {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  relation TaxonomyEdgeRelation

  fromTermId String
  toTermId   String
  fromTerm TaxonomyTerm @relation("TaxonomyEdge_from", fields: [fromTermId], references: [id], onDelete: Cascade)
  toTerm   TaxonomyTerm @relation("TaxonomyEdge_to", fields: [toTermId], references: [id], onDelete: Cascade)

  @@unique([fromTermId, toTermId, relation])
  @@index([fromTermId, relation])
  @@index([toTermId, relation])
}

model UserTaxonomyPreference {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  termId String

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  term TaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@unique([userId, termId])
  @@index([userId])
  @@index([termId])
}

model TaxonomyTermMetric {
  termId String @id
  updatedAt DateTime @updatedAt
  articleCount Int @default(0)
  postCount Int @default(0)
  hashtagCount Int @default(0)
  recentVelocity Float @default(0)
  engagementScore Float @default(0)

  term TaxonomyTerm @relation(fields: [termId], references: [id], onDelete: Cascade)

  @@index([engagementScore(sort: Desc)])
  @@index([recentVelocity(sort: Desc)])
}

/** Tracks last push sent per user+kind for rate limiting/coalescing. */
model PushCoalesce {
  userId String
  kind   String
  sentAt DateTime
  user   User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, kind])
  @@index([userId, kind])
}

model MessageConversation {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  type MessageConversationType
  title String?
  createdByUserId String
  /** Unique key for direct conversations (sorted user ids). */
  directKey String? @unique

  lastMessageAt DateTime?
  lastMessageId String? @unique

  createdBy User @relation("MessageConversation_createdBy", fields: [createdByUserId], references: [id], onDelete: Cascade)
  participants MessageParticipant[]
  messages Message[] @relation("MessageConversation_messages")
  lastMessage Message? @relation("MessageConversation_lastMessage", fields: [lastMessageId], references: [id], onDelete: SetNull)

  /** When this conversation is a crew wall (type: crew_wall), links back to the owning crew. */
  crewWall Crew? @relation("Crew_wallConversation")

  notifications Notification[] @relation("Notification_subjectConversation")

  @@index([type, updatedAt])
  @@index([lastMessageAt, id])
}

model MessageParticipant {
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  conversationId String
  userId String
  role MessageParticipantRole @default(member)
  status MessageParticipantStatus @default(pending)
  acceptedAt DateTime?
  lastReadAt DateTime?
  /** When set, push notifications for this conversation are silenced for the viewer. */
  mutedAt DateTime?

  conversation MessageConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user User @relation("MessageParticipant_user", fields: [userId], references: [id], onDelete: Cascade)

  @@id([conversationId, userId])
  @@index([userId, status, updatedAt])
  @@index([conversationId, updatedAt])
}

model Message {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  body      String   @db.Text

  conversationId String
  senderId String

  /** When set, this message is a reply to another message in the same conversation. */
  replyToId String?

  /** Set when the sender edits the message body. */
  editedAt DateTime?

  /** True when the sender has deleted the message for all participants. */
  deletedForAll    Boolean   @default(false)
  deletedForAllAt  DateTime?

  conversation MessageConversation @relation("MessageConversation_messages", fields: [conversationId], references: [id], onDelete: Cascade)
  sender User @relation("Message_sender", fields: [senderId], references: [id], onDelete: Cascade)
  lastMessageFor MessageConversation? @relation("MessageConversation_lastMessage")

  replyTo  Message?  @relation("Message_replies", fields: [replyToId], references: [id], onDelete: SetNull)
  replies  Message[] @relation("Message_replies")
  reactions MessageReaction[]
  deletions MessageDeletion[]
  media     MessageMedia[]

  @@index([conversationId, createdAt])
  @@index([senderId, createdAt])
  @@index([replyToId])
}

model MessageMedia {
  id        String          @id @default(cuid())
  createdAt DateTime        @default(now())
  kind      PostMediaKind
  source    PostMediaSource
  // For "upload" sources: r2Key is set; url is computed server-side.
  r2Key          String?
  thumbnailR2Key String?
  // For "giphy" sources: url/mp4Url are stored directly.
  url            String?
  mp4Url         String?
  width          Int?
  height         Int?
  durationSeconds Int?
  alt            String?

  messageId String
  message   Message @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([messageId])
}

model MessageReaction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  messageId  String
  userId     String
  reactionId String
  emoji      String

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageReaction_user", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, reactionId])
  @@index([messageId])
  @@index([userId, createdAt])
}

model MessageDeletion {
  messageId String
  userId    String
  deletedAt DateTime @default(now())

  message Message @relation(fields: [messageId], references: [id], onDelete: Cascade)
  user    User    @relation("MessageDeletion_user", fields: [userId], references: [id], onDelete: Cascade)

  @@id([messageId, userId])
  @@index([userId, deletedAt])
}

model UserBlock {
  createdAt DateTime @default(now())

  blockerId String
  blockedId String

  blocker User @relation("UserBlock_blocker", fields: [blockerId], references: [id], onDelete: Cascade)
  blocked User @relation("UserBlock_blocked", fields: [blockedId], references: [id], onDelete: Cascade)

  @@id([blockerId, blockedId])
  @@index([blockerId, createdAt])
  @@index([blockedId, createdAt])
}

model Feedback {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  category FeedbackCategory
  status   FeedbackStatus @default(new)
  email    String?        @db.VarChar(200)
  subject  String         @db.VarChar(200)
  details  String         @db.Text
  adminNote String?       @db.Text

  /** IP address of submitter (for rate limiting / abuse prevention). */
  submitterIp String? @db.VarChar(64)

  userId String?
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([createdAt, id])
  @@index([status, createdAt])
  @@index([category, createdAt])
  @@index([submitterIp, createdAt])
}

model Report {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  targetType ReportTargetType
  reason     ReportReason
  details    String?      @db.Text

  status     ReportStatus @default(pending)
  adminNote  String?      @db.Text
  resolvedAt DateTime?

  reporterUserId String
  reporter       User   @relation("Report_reporter", fields: [reporterUserId], references: [id], onDelete: Cascade)

  subjectUserId String?
  subjectUser   User?  @relation("Report_subjectUser", fields: [subjectUserId], references: [id], onDelete: Cascade)

  subjectPostId String?
  subjectPost   Post?  @relation("Report_subjectPost", fields: [subjectPostId], references: [id], onDelete: Cascade)

  resolvedByAdminId String?
  resolvedByAdmin   User? @relation("Report_resolvedBy", fields: [resolvedByAdminId], references: [id], onDelete: SetNull)

  @@index([createdAt, id])
  @@index([status, createdAt])
  @@index([targetType, createdAt])
  @@index([reporterUserId, createdAt])
  @@index([subjectUserId, createdAt])
  @@index([subjectPostId, createdAt])
}

model VerificationRequest {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  userId String
  user   User   @relation("VerificationRequest_user", fields: [userId], references: [id], onDelete: Cascade)

  status VerificationRequestStatus @default(pending)

  // Provider-agnostic fields (null until a provider is integrated).
  provider String? @db.VarChar(50)
  providerRequestId String? @db.VarChar(200)
  metadata Json?

  // Admin review fields.
  reviewedAt DateTime?
  reviewedByAdminId String?
  reviewedByAdmin User? @relation("VerificationRequest_reviewedBy", fields: [reviewedByAdminId], references: [id], onDelete: SetNull)
  adminNote String? @db.Text
  rejectionReason String? @db.Text

  @@index([createdAt, id])
  @@index([userId, createdAt])
  @@index([status, createdAt])
  @@index([provider, providerRequestId])
}

// Cached OpenGraph/link metadata for post previews (Microlink/Jina).
model LinkMetadata {
  id          String   @id @default(cuid())
  url         String   @unique
  title       String?
  description String?
  imageUrl    String?
  siteName    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([url])
}

/// Tracks admin digest emails sent per day so we never double-send.
model AdminEmailLog {
  id     String   @id @default(cuid())
  kind   String
  dayKey String
  sentAt DateTime @default(now())

  @@unique([kind, dayKey])
  @@index([sentAt])
}

// ─── Articles ────────────────────────────────────────────────────────────────

model Article {
  id          String          @id @default(cuid())
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt
  publishedAt DateTime?
  editedAt    DateTime?
  deletedAt   DateTime?

  title       String
  slug        String
  /** Tiptap document stored as stringified JSON. */
  body        String          @default("{}")
  /** Auto-generated plain-text excerpt (~200 chars). */
  excerpt     String?
  thumbnailR2Key String?

  visibility  PostVisibility  @default(public)
  isDraft     Boolean         @default(true)
  lastSavedAt DateTime        @default(now())

  boostCount   Int @default(0)
  commentCount Int @default(0)
  viewCount    Int @default(0)
  weightedViewCount Float @default(0)

  trendingScore          Float?
  trendingScoreUpdatedAt DateTime?

  /** The highest view-count milestone (50/100/500/1000) already notified to the author. */
  viewMilestoneNotified  Int?

  authorId String
  author   User   @relation(fields: [authorId], references: [id], onDelete: Cascade)

  boosts    ArticleBoost[]
  reactions ArticleReaction[]
  comments  ArticleComment[]
  views     ArticleView[]
  anonViews ArticleAnonView[]
  sharePosts Post[]
  tags      ArticleTag[]
  notifications Notification[] @relation("Notification_subjectArticle")

  @@index([authorId, createdAt])
  @@index([publishedAt(sort: Desc), id(sort: Desc)])
  @@index([trendingScore(sort: Desc), publishedAt(sort: Desc)])
  @@index([deletedAt])
  // Global article feeds (new): published + visibility with stable cursor ordering.
  @@index([deletedAt, isDraft, visibility, publishedAt(sort: Desc), id(sort: Desc)])
  // Global article feeds (trending): score-first ordering with visibility gating.
  @@index([deletedAt, isDraft, visibility, trendingScore(sort: Desc), publishedAt(sort: Desc), id(sort: Desc)])
  // Author-scoped article feeds (profile/author pages), new sort.
  @@index([authorId, deletedAt, isDraft, visibility, publishedAt(sort: Desc), id(sort: Desc)])
  // Author-scoped article feeds, trending sort.
  @@index([authorId, deletedAt, isDraft, visibility, trendingScore(sort: Desc), publishedAt(sort: Desc), id(sort: Desc)])
  @@unique([slug])
}

model ArticleTag {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  /** Normalized slug used as the uniqueness key (lowercase, alphanumeric + hyphens). */
  tag       String
  /** Display label as the author typed it (may have uppercase, e.g. "Stoicism"). */
  label     String

  articleId String
  article   Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@unique([articleId, tag])
  @@index([articleId])
  @@index([tag])
}

model ArticleBoost {
  id        String   @id @default(cuid())
  createdAt DateTime @default(now())

  articleId String
  userId    String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId])
  @@index([articleId, createdAt])
  @@index([userId, createdAt])
}

model ArticleReaction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  articleId  String
  userId     String
  reactionId String
  emoji      String

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([articleId, userId, reactionId])
  @@index([articleId])
  @@index([userId, createdAt])
}

model ArticleComment {
  id        String    @id @default(cuid())
  createdAt DateTime  @default(now())
  editedAt  DateTime?
  deletedAt DateTime?

  body String

  articleId String
  authorId  String
  parentId  String?

  /** Denormalized reply count (only meaningful on top-level comments). */
  replyCount Int @default(0)

  article  Article          @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author   User             @relation(fields: [authorId], references: [id], onDelete: Cascade)
  parent   ArticleComment?  @relation("ArticleComment_replies", fields: [parentId], references: [id], onDelete: Cascade)
  replies  ArticleComment[] @relation("ArticleComment_replies")
  reactions ArticleCommentReaction[]
  notifications Notification[] @relation("Notification_subjectArticleComment")

  @@index([articleId, createdAt])
  @@index([parentId, createdAt])
  @@index([authorId, createdAt])
  // Top-level and reply list queries: article+parent+deleted with createdAt cursoring.
  @@index([articleId, parentId, deletedAt, createdAt(sort: Desc), id(sort: Desc)], map: "ArticleComment_article_parent_deleted_created_desc_idx")
  @@index([articleId, parentId, deletedAt, createdAt(sort: Asc), id(sort: Asc)], map: "ArticleComment_article_parent_deleted_created_asc_idx")
}

model ArticleCommentReaction {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())

  commentId  String
  userId     String
  reactionId String
  emoji      String

  comment ArticleComment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId, reactionId])
  @@index([commentId])
  @@index([userId, createdAt])
}

model CoinTransfer {
  id          String   @id @default(cuid())
  createdAt   DateTime @default(now())
  senderId    String
  recipientId String
  kind        CoinTransferKind @default(transfer)
  amount      Int
  note        String?

  sender    User @relation("CoinTransfer_sender", fields: [senderId], references: [id])
  recipient User @relation("CoinTransfer_recipient", fields: [recipientId], references: [id])

  @@index([senderId, createdAt(sort: Desc)])
  @@index([recipientId, createdAt(sort: Desc)])
}

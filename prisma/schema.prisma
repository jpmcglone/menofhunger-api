// Singleton-ish table: holds site-wide configurable settings.
// Use `id=1` row as the canonical config.
model SiteConfig {
  id        Int      @id
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  postsPerWindow     Int @default(5)
  windowSeconds      Int @default(300)

  // Tier-specific post rate limits (excludes onlyMe posts).
  verifiedPostsPerWindow Int @default(5)
  verifiedWindowSeconds  Int @default(300)
  premiumPostsPerWindow  Int @default(5)
  premiumWindowSeconds   Int @default(300)
}

model PhoneOtp {
